# ── Frontend environment variables (.env in project root) ─────────────────────
# Copy this file to .env and fill in your values.
# VITE_* vars are bundled into the frontend — never put secrets here.

# Supabase (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# API base URL — leave empty for local (Vite proxy handles /api → localhost:8000)
# Set to your Render API URL + /api/v1 in production:
# VITE_API_BASE_URL=https://agenticproductmanager.onrender.com/api/v1
VITE_API_BASE_URL=
