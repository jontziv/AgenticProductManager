# ── Backend environment variables (backend/.env) ──────────────────────────────
# Copy this file to backend/.env and fill in your values.
# This file is safe to commit. Never commit the real backend/.env.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=local                  # local | preview | staging | production
LOG_LEVEL=INFO

# ── Supabase (Dashboard → Settings → API) ────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=<JWT secret from Settings → API → JWT Settings>

# ── Database (Dashboard → Settings → Database → Connection string → URI) ─────
# Use the "Session mode" URI (port 5432) for direct connections
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ── Groq (console.groq.com) ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_STRUCTURED=llama-3.3-70b-versatile
GROQ_MODEL_SYNTHESIS=llama-3.3-70b-versatile
GROQ_MODEL_EVAL=llama-3.3-70b-versatile
GROQ_MODEL_AUDIO=whisper-large-v3-turbo
GROQ_MODEL_AUDIO_FALLBACK=whisper-large-v3

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_RETRIES=3
WORKER_CONCURRENCY=2

# ── Export ────────────────────────────────────────────────────────────────────
EXPORT_STORAGE_BUCKET=exports

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your Vercel deployment URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pm-sidekick

# ── Optional: OpenTelemetry ───────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=pm-sidekick-api
